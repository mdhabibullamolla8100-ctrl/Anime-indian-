{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "url": { "type": "string" },
        "uploaderId": { "type": "string" },
        "views": { "type": "number" },
        "likedBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "type": { "type": "string", "enum": ["video", "short"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "uploaderId", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Tracks users following other users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followedId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/history/{videoId}": {
      "schema": "Video",
      "description": "User watch history"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Videos collection"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "System or user notifications"
    }
  }
}
